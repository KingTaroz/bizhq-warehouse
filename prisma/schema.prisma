// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name         String
  brand        String?
  viscosity    String?
  size         String?
  qtyPerCarton Int      @default(1)
  category     String?
  description  String?
  currentAvgCost Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  barcodes    Barcode[]
  inventory   Inventory[]
  skuItems    SkuItem[]
  transactionItems TransactionItem[]
  supplierMappings SupplierMapping[]
  costHistory CostPriceHistory[]
  platformProducts PlatformProduct[]
}

// แคตตาล็อกสินค้าบนแพลตฟอร์ม (Shopee/TikTok) 1 แถว = 1 ตัวเลือกสินค้า
// productId = จับคู่กับสินค้าจริงแล้ว (null = รอจับคู่เอง)
model PlatformProduct {
  id            String   @id @default(cuid())
  platform      String   // SHOPEE, TIKTOK
  itemId        String   // รหัสสินค้าบนแพลตฟอร์ม
  variationId   String   @default("") // รหัสตัวเลือก ("" = ไม่มีตัวเลือก)
  itemName      String
  variationName String?
  price         Float    @default(0)
  stock         Int      @default(0)
  productId     String?
  quantity      Int      @default(1) // จำนวนชิ้นจริงต่อ 1 หน่วยขาย (เช่น ยกลัง x12)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([platform, itemId, variationId])
}

model Barcode {
  id         String   @id @default(cuid())
  productId  String
  code       String   @unique
  type       String   @default("BOTTLE") // BOTTLE, CARTON
  multiplier Int      @default(1) // 1 for bottle, e.g., 24 for carton
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Sku {
  id         String    @id @default(cuid())
  platform   String    // SHOPEE, TIKTOK
  skuCode    String
  createdAt  DateTime  @default(now())

  items      SkuItem[]

  @@unique([platform, skuCode])
}

model SkuItem {
  id        String  @id @default(cuid())
  skuId     String
  productId String
  quantity  Int     @default(1)

  sku       Sku     @relation(fields: [skuId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Location {
  id        String   @id @default(cuid())
  name      String
  type      String   // STOREFRONT, FRONT_WH, MAIN_WH, DEFECT
  createdAt DateTime @default(now())

  inventory Inventory[]
  transactionItems TransactionItem[]
}

model Inventory {
  id         String   @id @default(cuid())
  productId  String
  locationId String
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model Transaction {
  id        String   @id @default(cuid())
  type      String   // INBOUND, OUTBOUND, DEFECT, ADJUSTMENT
  reference String?  // Invoice No, PO No
  notes     String?
  documentDate DateTime?
  createdAt DateTime @default(now())

  items     TransactionItem[]
}

model TransactionItem {
  id            String   @id @default(cuid())
  transactionId String
  productId     String
  locationId    String
  quantity      Int
  price         Float?   // Special price for DEFECT sale
  costPrice     Float    @default(0) // Captured at INBOUND
  createdAt     DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  location      Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("warehouse") // admin, warehouse
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformOrder {
  id            String   @id @default(cuid())
  platform      String   // SHOPEE, TIKTOK
  orderId       String   @unique
  trackingNo    String?  @unique
  status        String   @default("PENDING") // PENDING, PACKED, CANCELLED, RETURNED
  totalAmount   Float    @default(0)
  platformFee   Float    @default(0)
  orderDate     DateTime? // วันที่ขายจริงจากไฟล์แพลตฟอร์ม (createdAt = วันอัปโหลด)
  createdAt     DateTime @default(now())

  items         PlatformOrderItem[]
}

model PlatformOrderItem {
  id            String   @id @default(cuid())
  orderId       String
  skuCode       String
  quantity      Int      @default(1)
  unitCost      Float    @default(0) // Snapshot of Product's currentAvgCost
  unitPrice     Float    @default(0) // Selling price extracted from Excel
  
  order         PlatformOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SupplierMapping {
  id           String   @id @default(cuid())
  supplierName String   
  supplierCode String   
  productId    String   
  multiplier   Int      @default(1) 
  
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierName, supplierCode])
}

model CostPriceHistory {
  id            String   @id @default(cuid())
  productId     String
  costPrice     Float
  effectiveDate DateTime @default(now())

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

